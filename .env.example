# === Google Sheets ===
# Google Sheet 的 ID,可從網址擷取:docs.google.com/spreadsheets/d/{ID}/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account 的 JSON 檔內容(整段貼上)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# === Email 通知 ===
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_email@gmail.com
# Gmail 應用程式密碼(16 碼,非登入密碼)
EMAIL_SMTP_PASS=your_app_password_here
NOTIFY_EMAIL_TO=recipient@example.com

# === FinMind API(選用,Goodinfo 被擋時切換用)===
FINMIND_TOKEN=your_finmind_token_here

# === 其他 ===
# 日誌等級:DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
